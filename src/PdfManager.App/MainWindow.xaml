<Window x:Class="PdfManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PdfManager.App.ViewModels"
        xmlns:views="clr-namespace:PdfManager.App.Views"
        Title="{DynamicResource Str_AppTitle}"
        Height="860" Width="1280"
        MinWidth="700" MinHeight="480"
        TextOptions.TextFormattingMode="Display"
        FontFamily="Segoe UI, Inter, Arial"
        Background="{DynamicResource Brush.Window}"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        Stylus.IsPressAndHoldEnabled="False"
        Closing="Window_Closing">

    <Window.InputBindings>
        <KeyBinding Key="Z"        Modifiers="Ctrl"  Command="{Binding UndoCommand}"/>
        <KeyBinding Key="Y"        Modifiers="Ctrl"  Command="{Binding RedoCommand}"/>
        <KeyBinding Key="OemPlus"  Modifiers="Ctrl"  Command="{Binding ZoomInCommand}"/>
        <KeyBinding Key="OemMinus" Modifiers="Ctrl"  Command="{Binding ZoomOutCommand}"/>
        <KeyBinding Key="D0"       Modifiers="Ctrl"  Command="{Binding ZoomResetCommand}"/>
        <KeyBinding Key="Escape"                     Command="{Binding DeactivateToolCommand}"/>
    </Window.InputBindings>

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource Brush.Toolbar}"
                BorderBrush="{DynamicResource Brush.ToolbarBorder}"
                BorderThickness="0,0,0,1">
            <ToolBar Style="{StaticResource FlatToolBar}">

                <!-- File -->
                <!-- File menu -->
                <Button x:Name="FileMenuBtn" Content="File  ▾"
                        Style="{StaticResource BigButton}"
                        Click="FileMenuBtn_Click"/>
                <Popup x:Name="FileMenu" PlacementTarget="{Binding ElementName=FileMenuBtn}"
                       Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                    <Border Background="{DynamicResource Brush.Surface}"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1" CornerRadius="6" Padding="4">
                        <StackPanel MinWidth="180">
                            <Button Content="Nuovo documento…" Style="{StaticResource BigButton}"
                                    HorizontalContentAlignment="Left" Padding="12,7"
                                    Command="{Binding NewDocumentCommand}" Click="FileMenuItem_Click"/>
                            <Button Content="Apri…" Style="{StaticResource BigButton}"
                                    HorizontalContentAlignment="Left" Padding="12,7"
                                    Command="{Binding OpenCommand}" Click="FileMenuItem_Click"/>
                            <Separator Margin="8,2"/>
                            <Button Content="Salva" Style="{StaticResource BigButton}"
                                    HorizontalContentAlignment="Left" Padding="12,7"
                                    Command="{Binding SaveCommand}" Click="FileMenuItem_Click"/>
                            <Button Content="Salva con nome…" Style="{StaticResource BigButton}"
                                    HorizontalContentAlignment="Left" Padding="12,7"
                                    Command="{Binding SaveAsCommand}" Click="FileMenuItem_Click"/>
                            <Separator Margin="8,2"/>
                            <Button Content="Chiudi scheda" Style="{StaticResource BigButton}"
                                    HorizontalContentAlignment="Left" Padding="12,7"
                                    Command="{Binding CloseTabCommand}" Click="FileMenuItem_Click"/>
                        </StackPanel>
                    </Border>
                </Popup>

                <!-- Organizza menu -->
                <Button x:Name="OrgMenuBtn" Content="Organizza  ▾"
                        Style="{StaticResource BigButton}"
                        Click="OrgMenuBtn_Click"/>
                <Popup x:Name="OrgMenu" PlacementTarget="{Binding ElementName=OrgMenuBtn}"
                       Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                    <Border Background="{DynamicResource Brush.Surface}"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1" CornerRadius="6" Padding="4">
                        <StackPanel MinWidth="160">
                            <Button Content="Combina file…" Style="{StaticResource BigButton}"
                                    HorizontalContentAlignment="Left" Padding="12,7"
                                    Command="{Binding OpenCombineCommand}" Click="OrgMenuItem_Click"/>
                            <Button Content="Dividi PDF…" Style="{StaticResource BigButton}"
                                    HorizontalContentAlignment="Left" Padding="12,7"
                                    Command="{Binding OpenSplitCommand}" Click="OrgMenuItem_Click"/>
                        </StackPanel>
                    </Border>
                </Popup>
                <Separator/>

                <!-- Tools — mutually exclusive -->
                <ToggleButton Content="Penna"  Style="{StaticResource BigToggleButton}" IsChecked="{Binding IsPenMode}"    ToolTip="Penna (P)"/>

                <!-- Pen options popup (opens when clicking arrow) -->
                <Button x:Name="PenOptionsBtn"
                        Content="▾" Width="18" MinWidth="18" Padding="0"
                        Style="{StaticResource BigButton}"
                        Visibility="{Binding IsPenMode, Converter={StaticResource BoolToVis}}"
                        Click="PenOptionsBtn_Click"
                        ToolTip="Opzioni penna"/>

                <ToggleButton Content="Testo"   Style="{StaticResource BigToggleButton}" IsChecked="{Binding IsTextMode}"   ToolTip="Testo"/>
                <ToggleButton Content="Freccia" Style="{StaticResource BigToggleButton}" IsChecked="{Binding IsArrowMode}"  ToolTip="Freccia"/>
                <ToggleButton Content="Cerchio" Style="{StaticResource BigToggleButton}" IsChecked="{Binding IsCircleMode}" ToolTip="Cerchio/Ellisse"/>
                <ToggleButton Content="Gomma"   Style="{StaticResource BigToggleButton}" IsChecked="{Binding IsEraserMode}" ToolTip="Gomma"/>
                <ToggleButton Content="✋"      Style="{StaticResource BigToggleButton}" IsChecked="{Binding IsPanMode}"    ToolTip="Pan" FontSize="14"/>
                <ToggleButton Content="Testo PDF" Style="{StaticResource BigToggleButton}" IsChecked="{Binding IsOcrEditMode}" ToolTip="Modifica testo esistente (OCR)"/>
                <Separator/>

                <!-- Page ops -->
                <Button Content="↺" Style="{StaticResource BigButton}" Command="{Binding RotateLeftCommand}"  ToolTip="Ruota sx"/>
                <Button Content="↻" Style="{StaticResource BigButton}" Command="{Binding RotateRightCommand}" ToolTip="Ruota dx (R)"/>
                <Button Content="🗑" Style="{StaticResource BigButton}" Command="{Binding DeletePageCommand}"  ToolTip="Elimina pagina (Del)" FontSize="14"/>
                <Separator/>

                <!-- Undo/redo -->
                <Button Content="↩" Style="{StaticResource BigButton}" Command="{Binding UndoCommand}" ToolTip="Annulla (Ctrl+Z)"/>
                <Button Content="↪" Style="{StaticResource BigButton}" Command="{Binding RedoCommand}" ToolTip="Ripeti (Ctrl+Y)"/>
                <Separator/>

                <!-- Zoom -->
                <Button Content="−" Width="28" Style="{StaticResource BigButton}" Command="{Binding ZoomOutCommand}" ToolTip="Zoom out (Ctrl+-)"/>
                <Button Content="{Binding ZoomLabel}" MinWidth="48" Style="{StaticResource BigButton}" Command="{Binding ZoomResetCommand}" ToolTip="Reset zoom (Ctrl+0)" FontSize="12"/>
                <Button Content="+" Width="28" Style="{StaticResource BigButton}" Command="{Binding ZoomInCommand}"  ToolTip="Zoom in (Ctrl++)"/>

                <!-- Push remaining items right -->
                <Separator/>

                <!-- Dark mode toggle -->
                <ToggleButton Style="{StaticResource BigToggleButton}"
                              IsChecked="{Binding IsDarkMode, Mode=OneWay}"
                              Command="{Binding ToggleThemeCommand}"
                              ToolTip="Tema chiaro/scuro"
                              FontSize="15">
                    <ToggleButton.Content>
                        <TextBlock Text="{Binding IsDarkMode, Converter={StaticResource MoonSunConverter}}"
                                   FontFamily="Segoe UI Emoji"/>
                    </ToggleButton.Content>
                </ToggleButton>

            </ToolBar>
        </Border>

        <!-- Pen options popup (inline, positioned below toolbar) -->
        <Popup x:Name="PenPopup"
               PlacementTarget="{Binding ElementName=PenOptionsBtn}"
               Placement="Bottom"
               StaysOpen="False"
               AllowsTransparency="True">
            <Border Background="{DynamicResource Brush.Surface}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10,8"
                    Effect="{x:Null}">
                <StackPanel>
                    <!-- Color swatches -->
                    <TextBlock Text="Colore" FontSize="11"
                               Foreground="{DynamicResource Brush.TextMuted}"
                               Margin="0,0,0,5"
                               FontFamily="Segoe UI"/>
                    <ItemsControl ItemsSource="{Binding PenTool.Palette}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel Width="160"/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Width="24" Height="24" Margin="2"
                                        Padding="0"
                                        Tag="{Binding}"
                                        Click="SwatchClick"
                                        BorderThickness="1.5"
                                        Cursor="Hand">
                                    <Button.Background><SolidColorBrush Color="{Binding}"/></Button.Background>
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="bd"
                                                                Width="24" Height="24"
                                                                CornerRadius="12"
                                                                Background="{TemplateBinding Background}"
                                                                BorderBrush="Transparent"
                                                                BorderThickness="2">
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource Brush.Text}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Thickness -->
                    <TextBlock Text="Spessore" FontSize="11"
                               Foreground="{DynamicResource Brush.TextMuted}"
                               Margin="0,8,0,4"
                               FontFamily="Segoe UI"/>
                    <Slider Minimum="1" Maximum="14"
                            Value="{Binding PenTool.WidthPt}"
                            Width="160"
                            TickFrequency="1"
                            IsSnapToTickEnabled="True"/>
                    <TextBlock Text="{Binding PenTool.WidthPt, StringFormat='{}{0:0}pt'}"
                               FontSize="11" HorizontalAlignment="Center"
                               Foreground="{DynamicResource Brush.TextMuted}"
                               Margin="0,2,0,0"
                               FontFamily="Segoe UI"/>
                </StackPanel>
            </Border>
        </Popup>

        <!-- Tabs -->
        <TabControl x:Name="MainTabControl"
                    ItemsSource="{Binding OpenTabs}"
                    SelectedItem="{Binding ActiveTab}"
                    Background="{DynamicResource Brush.Background}">

            <TabControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:PdfTabViewModel}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Title}"
                                   VerticalAlignment="Center"
                                   MaxWidth="160"
                                   TextTrimming="CharacterEllipsis"
                                   FontSize="12"
                                   FontFamily="Segoe UI"
                                   Margin="6,0,4,0"/>
                        <Button Content="✕" Width="18" Height="18"
                                FontSize="10" Padding="0"
                                Background="Transparent" BorderThickness="0"
                                VerticalAlignment="Center"
                                CommandParameter="{Binding}"
                                Command="{Binding RelativeSource={RelativeSource AncestorType=TabControl},
                                                  Path=DataContext.CloseTabCommand}"
                                Stylus.IsPressAndHoldEnabled="False"
                                Cursor="Hand"/>
                    </StackPanel>
                </DataTemplate>
            </TabControl.ItemTemplate>

            <TabControl.ContentTemplate>
                <DataTemplate DataType="{x:Type vm:PdfTabViewModel}">
                    <views:PdfTabView Tag="{Binding RelativeSource={RelativeSource AncestorType=TabControl},
                                                    Path=DataContext.PenTool}"/>
                </DataTemplate>
            </TabControl.ContentTemplate>

            <TabControl.Style>
                <Style TargetType="TabControl">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding OpenTabs.Count}" Value="0">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TabControl">
                                        <Border Background="{DynamicResource Brush.Background}">
                                            <StackPanel HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="GP" FontSize="56"
                                                           FontWeight="Bold"
                                                           FontFamily="Segoe UI"
                                                           Foreground="{DynamicResource Brush.Accent}"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="{DynamicResource Str_DropHint}"
                                                           FontSize="14"
                                                           FontFamily="Segoe UI"
                                                           Foreground="{DynamicResource Brush.TextMuted}"
                                                           HorizontalAlignment="Center"
                                                           TextAlignment="Center"
                                                           TextWrapping="Wrap"
                                                           MaxWidth="360"
                                                           Margin="0,12,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Style>
        </TabControl>
    </DockPanel>
</Window>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conv="clr-namespace:PdfManager.App.Converters">

    <!-- Converters — defined here (Application-level) so all UserControls can resolve them -->
    <conv:BooleanToVisibilityConverter x:Key="BoolToVis"/>
    <conv:BooleanToVisibilityConverter x:Key="BoolToVisInv" Invert="True"/>

    <SolidColorBrush x:Key="Brush.Background"      Color="#FFF7F7F8"/>
    <SolidColorBrush x:Key="Brush.Surface"         Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="Brush.Border"          Color="#FFD0D5DC"/>
    <SolidColorBrush x:Key="Brush.Text"            Color="#FF1E293B"/>
    <SolidColorBrush x:Key="Brush.TextMuted"       Color="#FF64748B"/>
    <SolidColorBrush x:Key="Brush.Accent"          Color="#FF2563EB"/>
    <SolidColorBrush x:Key="Brush.AccentHover"     Color="#FF1D4ED8"/>
    <SolidColorBrush x:Key="Brush.AccentPressed"   Color="#FF1E3A8A"/>
    <SolidColorBrush x:Key="Brush.Danger"          Color="#FFDC2626"/>

    <Style x:Key="BigButton" TargetType="Button">
        <Setter Property="MinHeight"  Value="44"/>
        <Setter Property="MinWidth"   Value="44"/>
        <Setter Property="Padding"    Value="12,8"/>
        <Setter Property="FontSize"   Value="15"/>
        <Setter Property="Background" Value="{StaticResource Brush.Surface}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
        <Setter Property="Margin" Value="3,0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Stylus.IsPressAndHoldEnabled" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#FFEFF4FF"/>
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Brush.Accent}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#FFE0EAFF"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="BigToggleButton" TargetType="ToggleButton">
        <Setter Property="MinHeight"  Value="44"/>
        <Setter Property="MinWidth"   Value="44"/>
        <Setter Property="Padding"    Value="12,8"/>
        <Setter Property="FontSize"   Value="15"/>
        <Setter Property="Background" Value="{StaticResource Brush.Surface}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
        <Setter Property="Margin" Value="3,0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Stylus.IsPressAndHoldEnabled" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#FFEFF4FF"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource Brush.Accent}"/>
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Brush.AccentHover}"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>

<UserControl x:Class="PdfManager.App.Views.PdfTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dd="urn:gong-wpf-dragdrop"
             xmlns:vm="clr-namespace:PdfManager.App.ViewModels"
             xmlns:ctrl="clr-namespace:PdfManager.App.Controls"
             xmlns:views="clr-namespace:PdfManager.App.Views">
    <!-- DataContext = PdfTabViewModel, PenTool passed via Tag from MainWindow -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180" MinWidth="120" MaxWidth="280"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Thumbnail sidebar -->
        <Grid Grid.Column="0" Background="{DynamicResource Brush.Background}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal"
                        Background="{DynamicResource Brush.Surface}"
                        Margin="4,4,4,4">
                <Button Content="↺"  FontSize="18" ToolTip="{DynamicResource Str_RotateLeft}"
                        Style="{StaticResource BigButton}" Width="44"
                        Command="{Binding RotatePageLeftCommand}"/>
                <Button Content="↻"  FontSize="18" ToolTip="{DynamicResource Str_RotateRight}"
                        Style="{StaticResource BigButton}" Width="44"
                        Command="{Binding RotatePageRightCommand}"/>
                <Button Content="🗑" FontSize="18" ToolTip="{DynamicResource Str_DeletePage}"
                        Style="{StaticResource BigButton}" Width="44"
                        Command="{Binding DeletePageCommand}"/>
            </StackPanel>

            <ListBox Grid.Row="1"
                     ItemsSource="{Binding Pages}"
                     SelectedItem="{Binding CurrentPage}"
                     BorderThickness="0"
                     Background="{DynamicResource Brush.Background}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     dd:DragDrop.IsDragSource="True"
                     dd:DragDrop.IsDropTarget="True"
                     dd:DragDrop.DropHandler="{Binding}">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:PageViewModel}">
                        <Border Margin="6,4" Padding="4"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="1" Background="White"
                                CornerRadius="4">
                            <StackPanel>
                                <Image Source="{Binding ThumbnailImage}"
                                       MaxHeight="160" Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                <TextBlock Text="{Binding Label}"
                                           FontSize="11" HorizontalAlignment="Center"
                                           Margin="0,4,0,0"
                                           Foreground="{DynamicResource Brush.TextMuted}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="2"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#FFE0EAFF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </Grid>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="5"
                      HorizontalAlignment="Stretch"
                      Background="{DynamicResource Brush.Border}"/>

        <!-- Main canvas: ScrollViewer + page + ink -->
        <ScrollViewer x:Name="MainScroll"
                      Grid.Column="2"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      PanningMode="Both"
                      Background="#FFE8ECF0">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Margin="24">
                <Grid.LayoutTransform>
                    <ScaleTransform ScaleX="{Binding Zoom}" ScaleY="{Binding Zoom}"/>
                </Grid.LayoutTransform>
                <ctrl:PdfPageView DataContext="{Binding CurrentPage}"
                                  PenTool="{Binding RelativeSource={RelativeSource AncestorType=UserControl},
                                                    Path=Tag}"
                                  IsTextMode="{Binding RelativeSource={RelativeSource AncestorType=TabControl},
                                                       Path=DataContext.IsTextMode}"/>
            </Grid>
        </ScrollViewer>

        <!-- Pen toolbar (right rail) -->
        <views:PenToolbarView Grid.Column="3"
                              DataContext="{Binding RelativeSource={RelativeSource AncestorType=UserControl},
                                                   Path=Tag}"/>
    </Grid>
</UserControl>

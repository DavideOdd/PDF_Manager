<Window x:Class="PdfManager.App.Views.Dialogs.NewDocumentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nuovo documento"
        Width="400" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FontFamily="Segoe UI"
        Background="{DynamicResource Brush.Window}"
        Foreground="{DynamicResource Brush.Text}">
    <StackPanel Margin="20">
        <TabControl x:Name="Tabs" Background="Transparent">
            <!-- Formati carta -->
            <TabItem Header="Formato carta">
                <StackPanel Margin="0,12,0,0">
                    <TextBlock Text="Formato:" FontSize="13" Margin="0,0,0,8"/>
                    <ListBox x:Name="PaperList" FontSize="13" Height="180"
                             BorderBrush="{DynamicResource Brush.Border}">
                        <ListBoxItem Content="A4 verticale   (210 × 297 mm)"  Tag="595,842"  IsSelected="True"/>
                        <ListBoxItem Content="A4 orizzontale (297 × 210 mm)"  Tag="842,595"/>
                        <ListBoxItem Content="A3 verticale   (297 × 420 mm)"  Tag="842,1191"/>
                        <ListBoxItem Content="A3 orizzontale (420 × 297 mm)"  Tag="1191,842"/>
                        <ListBoxItem Content="A5 verticale   (148 × 210 mm)"  Tag="420,595"/>
                        <ListBoxItem Content="Letter verticale (216 × 279 mm)" Tag="612,792"/>
                        <ListBoxItem Content="Letter orizzontale (279 × 216 mm)" Tag="792,612"/>
                        <ListBoxItem Content="Legal (216 × 356 mm)"           Tag="612,1008"/>
                    </ListBox>
                </StackPanel>
            </TabItem>
            <!-- Dimensioni pixel -->
            <TabItem Header="Dimensioni pixel">
                <StackPanel Margin="0,12,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Larghezza:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                        <TextBox x:Name="PixW" Grid.Column="1" Text="1240" FontSize="13" Height="28" Margin="0,0,0,8" Padding="6,2"/>
                        <TextBlock Grid.Row="1" Text="Altezza:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                        <TextBox x:Name="PixH" Grid.Row="1" Grid.Column="1" Text="1754" FontSize="13" Height="28" Margin="0,0,0,8" Padding="6,2"/>
                        <TextBlock Grid.Row="2" Text="DPI:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox x:Name="DpiBox" Grid.Row="2" Grid.Column="1" FontSize="13" Height="28" SelectedIndex="1">
                            <ComboBoxItem Content="72 dpi"/>
                            <ComboBoxItem Content="96 dpi"/>
                            <ComboBoxItem Content="150 dpi"/>
                            <ComboBoxItem Content="300 dpi"/>
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </TabItem>
        </TabControl>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Annulla" Style="{StaticResource BigButton}" IsCancel="True" Margin="0,0,8,0"/>
            <Button Content="Crea" Style="{StaticResource BigButton}" IsDefault="True" Click="Create_Click"/>
        </StackPanel>
    </StackPanel>
</Window>

<Window x:Class="PdfManager.App.Views.Dialogs.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Str_DialogPasswordTitle}"
        Width="400" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <StackPanel Margin="24">
        <TextBlock x:Name="PromptText"
                   Text="{DynamicResource Str_DialogPasswordPrompt}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"
                   FontSize="14"/>
        <PasswordBox x:Name="PwdBox"
                     Height="38"
                     FontSize="14"
                     Margin="0,0,0,16"
                     KeyDown="PwdBox_KeyDown"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{DynamicResource Str_DialogCancel}"
                    Style="{StaticResource BigButton}"
                    IsCancel="True"
                    Margin="0,0,8,0"
                    Click="Cancel_Click"/>
            <Button Content="{DynamicResource Str_DialogOk}"
                    Style="{StaticResource BigButton}"
                    IsDefault="True"
                    Click="Ok_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
